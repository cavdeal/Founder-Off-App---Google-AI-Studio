rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isAuthenticated() {
       return request.auth != null;
    }
    
    function isOwner(userId) {
       return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        (request.auth.token.email == "cavdeal1@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    // Users collection
    match /users/{userId} {
      // Allow users to read their own profile or admins to read all
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      
      // Allow users to create their own profile
      allow create: if isAuthenticated() && request.auth.uid == userId;
      
      // Only admins can update roles, but users can update their own non-role data
      // For simplicity in this phase, allow owners to update their own docs
      allow update: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
      
      allow delete: if isAdmin();
    }

    // Projects collection
    match /projects/{projectId} {
      allow read: if isAuthenticated();

      // Only GM, BU Head, Admin can create new rows
      allow create: if isAuthenticated() && (
        isAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['gm', 'bu_head'])
      );

      // Update rules
      allow update: if isAuthenticated();

      // Only Admin can delete
      allow delete: if isAdmin();
    }
  }
}
